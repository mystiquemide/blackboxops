# ─── Auth ────────────────────────────────────────────────────────────────────

# Set to "local" for email/password auth, "google" to require Google OAuth
AUTH_PROVIDER=local

# Used to sign JWT tokens. Generate a random 64-char string for production.
SESSION_SECRET=

USE_MOCK_AUTH=true

FRONTEND_URL=http://127.0.0.1:5173
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://127.0.0.1:8000/api/auth/google/callback

# ─── Splunk ───────────────────────────────────────────────────────────────────

# Set true to skip all real Splunk calls and use deterministic sample data
USE_MOCK_SPLUNK=true

# ── Splunk MCP Server (live SPL search via official MCP server) ──
USE_SPLUNK_MCP=false

# Splunk Cloud: https://your-host.splunkcloud.com:443/en-US/splunkd/__raw/services/mcp
# Local Enterprise: https://localhost:8089/services/mcp/
SPLUNK_MCP_URL=

SPLUNK_MCP_TOKEN=

# true for Splunk Cloud (valid TLS cert); false for local self-signed certs
SPLUNK_MCP_VERIFY_TLS=true

# ── Splunk HEC (event ingestion) ──
SPLUNK_HEC_TOKEN=

# Splunk Cloud: https://inputs.your-host.splunkcloud.com:8088/services/collector/event
SPLUNK_HEC_URL=

# ── Splunk REST (optional, for non-MCP mode) ──
SPLUNK_HOST=https://localhost:8089
SPLUNK_PORT=8089
SPLUNK_TOKEN=
SPLUNK_INDEX=blackboxops

# TLS certificate verification for Splunk REST/HEC calls. Defaults to true.
# Only set to false for a Splunk instance with a self-signed cert you trust.
SPLUNK_VERIFY_TLS=true

# Operator bearer-token lifetime in hours; sessions expire after this window.
BLACKBOXOPS_SESSION_TTL_HOURS=24

# ─── Storage ─────────────────────────────────────────────────────────────────

BLACKBOXOPS_EVENT_STORE=data/blackbox_events.jsonl
BLACKBOXOPS_POLICY_FILE=policies/default.yaml
BLACKBOXOPS_AUTH_STORE=data/auth_users.jsonl

# ─── Optional ────────────────────────────────────────────────────────────────

LLM_API_KEY=
